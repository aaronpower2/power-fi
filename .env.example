# Copy to `.env.local` in the project root (same folder as package.json).
# Next.js and Drizzle Kit both read DATABASE_URL from there.

DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/power_fi

# Examples (adjust to your local Postgres):
# DATABASE_URL=postgresql://postgres@127.0.0.1:5432/power_fi
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/power_fi

# Vercel + Supabase: set DATABASE_URL in Vercel to the Transaction pooler URI
# (Project Settings → Database). For local migrations, prefer the direct URI.
# See docs/deploy-vercel-supabase.md

# Optional: transaction import AI matching (Anthropic)
ANTHROPIC_API_KEY=
# Optional — omit to use app default (claude-sonnet-4-20250514). Override with any current API model id.
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Where uploaded statement files are stored (relative to project root)
IMPORT_FILES_DIR=.data/imports

# Import matching: default is 1 concurrent API call (avoids output-token-per-minute limits).
# ANTHROPIC_MATCH_CONCURRENCY=2
# Optional cap on max output tokens per chunk request (default 4096)
# ANTHROPIC_MATCH_MAX_OUTPUT_TOKENS=4096

# Optional: default statement currency when parsing imports if no active goal currency (default AED in code).
# DEFAULT_IMPORT_CURRENCY=AED

# Optional: max few-shot examples injected into AI import matching (default 24, max 80).
# IMPORT_FEW_SHOT_LIMIT=24
